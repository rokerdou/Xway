version: '3.8'

services:
  socks5-server:
    build:
      context: .
      dockerfile: server/Dockerfile
    image: socks5-proxy-server:latest
    container_name: socks5-server
    restart: unless-stopped
    ports:
      - "1080:1080"
    environment:
      - RUST_LOG=info
      - SERVER_ADDRESS=0.0.0.0:1080
    networks:
      - socks5-network
    healthcheck:
      test: ["CMD", "nc", "-z", "localhost", "1080"]
      interval: 30s
      timeout: 3s
      retries: 3
      start_period: 10s

networks:
  socks5-network:
    driver: bridge
