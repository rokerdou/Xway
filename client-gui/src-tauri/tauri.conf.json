{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "SOCKS5 Proxy",
  "version": "0.1.0",
  "identifier": "com.socks5proxy.client",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd ui && pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SOCKS5 代理客户端",
        "width": 400,
        "height": 680,
        "resizable": true,
        "center": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://tauri.localhost https://tauri.localhost;"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/2x32.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "tray-icon": {
      "iconPath": "icons/icon@2xTemplate.png",
      "iconAsTemplate": true
    },
    "clipboard-manager": null
  }
}
